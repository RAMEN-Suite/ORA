{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/annotations.schema.json",
  "title": "ORA Annotations",
  "type": "object",
  "additionalProperties": false,
  "required": ["definitions"],
  "properties": {
    "definitions": {
      "type": "object",
      "description": "Maps annotation type names to render definitions.",
      "additionalProperties": {
        "$ref": "#/$defs/annotationDefinition"
      }
    },
    "unknownAnnotation": {
      "$ref": "#/$defs/unknownAnnotationStrategy",
      "default": "warn"
    },
    "invalidRange": {
      "$ref": "#/$defs/invalidRangeStrategy",
      "default": "warn"
    }
  },
  "$defs": {
    "annotationDefinition": {
      "oneOf": [
        {
          "$ref": "#/$defs/inlineDefinition"
        },
        {
          "$ref": "#/$defs/structureDefinition"
        },
        {
          "$ref": "#/$defs/layoutDefinition"
        },
        {
          "$ref": "#/$defs/zeroPointDefinition"
        }
      ]
    },
    "definitionBase": {
      "type": "object",
      "properties": {
        "priority": {
          "type": "integer",
          "description": "Optional ordering hint. Lower priority wraps outside higher priority annotations."
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "tokens": {
          "type": "array",
          "description": "Maps whitespace-separated tokens from annotation properties to CSS classes.",
          "items": {
            "$ref": "#/$defs/annotationTokenMapping"
          },
          "default": []
        }
      }
    },
    "inlineDefinition": {
      "allOf": [
        {
          "$ref": "#/$defs/definitionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["layer"],
          "properties": {
            "layer": {
              "const": "inline"
            },
            "behavior": {
              "$ref": "#/$defs/inlineBehavior",
              "default": "mark"
            },
            "renderAs": {
              "$ref": "#/$defs/inlineRenderElement",
              "default": "span"
            },
            "priority": {
              "type": "integer"
            },
            "classes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "tokens": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/annotationTokenMapping"
              },
              "default": []
            },
            "popover": {
              "$ref": "#/$defs/annotationPopover"
            }
          }
        }
      ]
    },
    "structureDefinition": {
      "allOf": [
        {
          "$ref": "#/$defs/definitionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["layer"],
          "properties": {
            "layer": {
              "const": "structure"
            },
            "behavior": {
              "$ref": "#/$defs/structureBehavior",
              "default": "mark"
            },
            "renderAs": {
              "$ref": "#/$defs/structureRenderElement",
              "default": "div"
            },
            "priority": {
              "type": "integer"
            },
            "classes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "tokens": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/annotationTokenMapping"
              },
              "default": []
            }
          }
        }
      ]
    },
    "layoutDefinition": {
      "allOf": [
        {
          "$ref": "#/$defs/definitionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["layer", "layoutRole", "renderAs"],
          "properties": {
            "layer": {
              "const": "layout"
            },
            "behavior": {
              "$ref": "#/$defs/layoutBehavior",
              "default": "mark"
            },
            "layoutRole": {
              "$ref": "#/$defs/layoutRole"
            },
            "renderAs": {
              "$ref": "#/$defs/layoutRenderElement"
            },
            "priority": {
              "type": "integer"
            },
            "classes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "tokens": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/annotationTokenMapping"
              },
              "default": []
            }
          }
        }
      ]
    },
    "zeroPointDefinition": {
      "allOf": [
        {
          "$ref": "#/$defs/definitionBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["layer", "behavior"],
          "properties": {
            "layer": {
              "const": "zero-point"
            },
            "behavior": {
              "$ref": "#/$defs/zeroPointBehavior"
            },
            "placement": {
              "$ref": "#/$defs/annotationPlacement",
              "default": "inline"
            },
            "priority": {
              "type": "integer"
            },
            "classes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "tokens": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/annotationTokenMapping"
              },
              "default": []
            },
            "label": {
              "type": "array",
              "description": "Values used to render the visible zero-point marker label.",
              "items": {
                "$ref": "#/$defs/annotationValue"
              },
              "default": []
            }
          }
        }
      ]
    },
    "annotationTokenMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["property", "mappings"],
      "properties": {
        "property": {
          "type": "string",
          "minLength": 1,
          "description": "Annotation property containing whitespace-separated tokens."
        },
        "mappings": {
          "type": "object",
          "description": "Maps token values to CSS classes.",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "annotationPopover": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Static title shown in the annotation popover."
        },
        "description": {
          "type": "array",
          "description": "Description values shown in the popover. Each binding is resolved by the backend view endpoint relative to the annotation node.",
          "items": {
            "$ref": "#/$defs/annotationValue"
          },
          "default": []
        },
        "externalLink": {
          "$ref": "#/$defs/annotationValue",
          "description": "Binding resolving to an external URL."
        },
        "references": {
          "type": "array",
          "description": "Referenced nodes shown in the popover.",
          "items": {
            "$ref": "#/$defs/annotationReference"
          },
          "default": []
        }
      }
    },
    "annotationValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "RAMEN access path resolved by the backend view endpoint relative to the annotation node."
        },
        "display": {
          "type": "string",
          "description": "Optional display template. The placeholder {{ value }} is replaced with the resolved value."
        },
        "translationKey": {
          "type": "string",
          "description": "Optional translation key used to render the resolved value."
        },
        "annotations": {
          "$ref": "#/$defs/binding",
          "description": "Optional binding resolving to annotations for this description value."
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "RAMEN access path resolved by the backend view endpoint."
        }
      }
    },
    "annotationReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "uuid"],
      "properties": {
        "label": {
          "$ref": "#/$defs/annotationValue",
          "description": "Binding resolving to the reference display label."
        },
        "uuid": {
          "$ref": "#/$defs/binding",
          "description": "Binding resolving to the referenced node UUID."
        },
        "icon": {
          "type": "string",
          "description": "Optional icon class, for example a PrimeIcons class."
        }
      }
    },
    "annotationPlacement": {
      "type": "string",
      "enum": ["inline", "margin"],
      "default": "inline"
    },
    "inlineBehavior": {
      "type": "string",
      "enum": ["mark", "popover", "hidden"]
    },
    "structureBehavior": {
      "type": "string",
      "enum": ["mark", "hidden"]
    },
    "layoutBehavior": {
      "type": "string",
      "enum": ["mark", "hidden"]
    },
    "zeroPointBehavior": {
      "type": "string",
      "enum": ["line-break", "marker", "hidden"]
    },
    "inlineRenderElement": {
      "type": "string",
      "enum": ["span", "abbr", "cite", "code", "em", "mark", "strong", "sub", "sup"]
    },
    "structureRenderElement": {
      "type": "string",
      "enum": ["div", "p", "section", "article", "header", "footer", "address", "blockquote", "h1", "h2", "h3", "h4", "h5", "h6"]
    },
    "layoutRenderElement": {
      "type": "string",
      "enum": ["ul", "ol", "li", "table", "thead", "tbody", "tr", "th", "td"]
    },
    "layoutRole": {
      "type": "string",
      "enum": ["list", "list-item", "table", "table-section", "table-row", "table-cell"]
    },
    "unknownAnnotationStrategy": {
      "type": "string",
      "enum": ["ignore", "plain", "warn"]
    },
    "invalidRangeStrategy": {
      "type": "string",
      "enum": ["ignore", "clamp", "warn"]
    }
  }
}
