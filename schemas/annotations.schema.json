{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/annotations.schema.json",
  "title": "ORA Annotations",
  "type": "object",
  "additionalProperties": false,
  "required": ["definitions"],
  "properties": {
    "definitions": {
      "type": "object",
      "description": "Maps annotation type names to render definitions.",
      "additionalProperties": {
        "$ref": "#/$defs/annotationDefinition"
      }
    },
    "classMappings": {
      "type": "object",
      "description": "Maps tokens read from annotation classProperty values to CSS classes. Example: #b -> ['font-bold'].",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "default": {}
    },
    "unknownAnnotation": {
      "$ref": "#/$defs/unknownAnnotationStrategy",
      "default": "warn"
    },
    "invalidRange": {
      "$ref": "#/$defs/invalidRangeStrategy",
      "default": "warn"
    }
  },
  "$defs": {
    "annotationDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layer"],
      "properties": {
        "layer": {
          "$ref": "#/$defs/annotationLayer"
        },
        "behavior": {
          "$ref": "#/$defs/annotationBehavior",
          "description": "Render behavior. If omitted, the renderer applies a layer-specific default."
        },
        "priority": {
          "type": "integer",
          "description": "Optional ordering hint. Lower priority wraps outside higher priority annotations."
        },
        "placement": {
          "$ref": "#/$defs/annotationPlacement",
          "description": "Controls where a zero-point annotation is rendered. Usually only relevant for page breaks."
        },
        "classes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "classProperty": {
          "type": "string",
          "description": "Annotation property whose whitespace-separated tokens should be mapped through classMappings."
        },
        "popover": {
          "$ref": "#/$defs/annotationPopover"
        }
      }
    },
    "annotationPopover": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { 
          "type": "string",
          "description": "Static title shown in the annotation popover."
        },
        "description": {
          "type": "array",
          "description": "Description values shown in the popover. Each binding is resolved by the backend view endpoint relative to the annotation node.",
          "items": {
            "$ref": "#/$defs/binding"
          },
          "default": []
        },
        "externalLink": {
          "$ref": "#/$defs/binding",
          "description": "Binding resolving to an external URL."
        },
        "references": {
          "type": "array",
          "description": "Referenced nodes shown in the popover.",
          "items": {
            "$ref": "#/$defs/annotationReference"
          },
          "default": []
        }
      }
    },
    "annotationReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "uuid"],
      "properties": {
        "label": {
          "$ref": "#/$defs/binding",
          "description": "Binding resolving to the reference display label."
        },
        "uuid": {
          "$ref": "#/$defs/binding",
          "description": "Binding resolving to the referenced node UUID."
        },
        "icon": {
          "type": "string",
          "description": "Optional icon class, for example a PrimeIcons class."
        }
      }
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "RAMEN access path resolved by the backend view endpoint relative to the annotation node."
        }
      }
    },
    "annotationPlacement": {
      "type": "string",
      "enum": ["inline", "margin"],
      "default": "inline"
    },
    "annotationLayer": {
      "type": "string",
      "enum": ["inline", "structure", "zero-point"]
    },
    "annotationBehavior": {
      "type": "string",
      "enum": ["mark", "popover", "line-break", "page-break", "gap", "hidden"]
    },
    "unknownAnnotationStrategy": {
      "type": "string",
      "enum": ["ignore", "plain", "warn"]
    },
    "invalidRangeStrategy": {
      "type": "string",
      "enum": ["ignore", "clamp", "warn"]
    }
  }
}
