{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/details.schema.json",
  "title": "ORA Details",
  "$ref": "#/$defs/detailViews",
  "$defs": {
    "bindingPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:\\[\\]*-]+$"
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": {
          "$ref": "#/$defs/bindingPath"
        }
      }
    },
    "bindingOrString": {
      "oneOf": [
        {
          "$ref": "#/$defs/binding"
        },
        {
          "type": "string"
        }
      ]
    },
    "headlineProps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": {
          "$ref": "#/$defs/binding"
        }
      }
    },
    "textProps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "title": {
          "$ref": "#/$defs/bindingOrString"
        },
        "text": {
          "$ref": "#/$defs/binding"
        },
        "annotations": {
          "$ref": "#/$defs/binding"
        }
      }
    },
    "attributesValueItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "label": {
          "type": "string"
        },
        "isEmptyVisible": {
          "type": "boolean"
        },
        "emptyLabel": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "value"
        },
        "value": {
          "$ref": "#/$defs/binding"
        }
      }
    },
    "attributesNodeItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "kind", "value", "property"],
      "properties": {
        "label": {
          "type": "string"
        },
        "isEmptyVisible": {
          "type": "boolean"
        },
        "emptyLabel": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "node"
        },
        "value": {
          "$ref": "#/$defs/binding"
        },
        "property": {
          "type": "string"
        },
        "isLinked": {
          "type": "boolean"
        }
      }
    },
    "attributesItem": {
      "oneOf": [
        {
          "$ref": "#/$defs/attributesNodeItem"
        },
        {
          "$ref": "#/$defs/attributesValueItem"
        }
      ]
    },
    "attributesProps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "title"],
      "properties": {
        "title": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attributesItem"
          }
        }
      }
    },
    "headlineBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "type": "string",
          "const": "headline"
        },
        "properties": {
          "$ref": "#/$defs/headlineProps"
        }
      }
    },
    "attributesBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "type": "string",
          "const": "attributes"
        },
        "properties": {
          "$ref": "#/$defs/attributesProps"
        }
      }
    },
    "textBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "type": "string",
          "const": "text"
        },
        "properties": {
          "$ref": "#/$defs/textProps"
        }
      }
    },
    "block": {
      "oneOf": [
        {
          "$ref": "#/$defs/headlineBlock"
        },
        {
          "$ref": "#/$defs/attributesBlock"
        },
        {
          "$ref": "#/$defs/textBlock"
        }
      ]
    },
    "detailView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match", "blocks"],
      "properties": {
        "match": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      }
    },
    "detailViews": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity", "collection"],
      "properties": {
        "entity": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detailView"
          }
        },
        "collection": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detailView"
          }
        }
      }
    }
  }
}
