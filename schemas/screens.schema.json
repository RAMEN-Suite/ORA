{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/screens.schema.json",
  "title": "ORA Screens",
  "$ref": "#/$defs/screens",
  "$defs": {
    "typeKey": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },
    "accessPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:\\[\\]*-]+$"
    },
    "access": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "$ref": "#/$defs/accessPath" }
      },
      "additionalProperties": false
    },
    "accessValueString": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/access" }
      ]
    },
    "valueMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },

    "option": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "icon": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "typeOption": {
      "allOf": [
        { "$ref": "#/$defs/option" },
        {
          "type": "object",
          "properties": {
            "value": { "$ref": "#/$defs/typeKey" }
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "accessOption": {
      "allOf": [
        { "$ref": "#/$defs/option" },
        {
          "type": "object",
          "properties": {
            "value": { "$ref": "#/$defs/accessPath" }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "property": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/accessPath" },
        "display": { "type": "string" },
        "valueMap": { "$ref": "#/$defs/valueMap" }
      },
      "additionalProperties": false
    },

    "filterOption": {
      "allOf": [
        { "$ref": "#/$defs/accessOption" },
        {
          "type": "object",
          "properties": {
            "display": { "type": "string", "enum": ["list", "range"] },
            "valueMap": { "$ref": "#/$defs/valueMap" }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "sortOptionGroup": {
      "type": "object",
      "required": ["initial", "options", "direction"],
      "properties": {
        "initial": { "$ref": "#/$defs/accessPath" },
        "direction": { "type": "string", "enum": ["asc", "desc"] },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/accessOption" }
        }
      },
      "additionalProperties": false
    },

    "listOption": {
      "allOf": [
        { "$ref": "#/$defs/typeOption" },
        {
          "type": "object",
          "properties": {
            "properties": {
              "type": "array",
              "items": { "$ref": "#/$defs/property" }
            },
            "sort": { "$ref": "#/$defs/sortOptionGroup" },
            "filters": {
              "type": "array",
              "items": { "$ref": "#/$defs/filterOption" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "entityOption": {
      "allOf": [
        { "$ref": "#/$defs/typeOption" },
        {
          "type": "object",
          "properties": {
            "properties": {
              "type": "array",
              "items": { "$ref": "#/$defs/property" }
            },
            "index": { "type": "string", "enum": ["character", "bible"] }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "listScreen": {
      "type": "object",
      "required": ["initial", "options"],
      "properties": {
        "initial": { "$ref": "#/$defs/typeKey" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/listOption" }
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/property" }
        }
      },
      "additionalProperties": false
    },

    "entityListScreen": {
      "type": "object",
      "required": ["initial", "options"],
      "properties": {
        "initial": { "$ref": "#/$defs/typeKey" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/entityOption" }
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/property" }
        }
      },
      "additionalProperties": false
    },

    "headlineBlock": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": { "const": "headline" },
        "properties": {
          "type": "object",
          "required": ["title"],
          "properties": {
            "title": { "$ref": "#/$defs/accessValueString" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "textBlock": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": { "const": "text" },
        "properties": {
          "type": "object",
          "required": ["text"],
          "properties": {
            "title": { "$ref": "#/$defs/accessValueString" },
            "text": { "$ref": "#/$defs/accessValueString" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "metadataValueItem": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "kind": { "const": "value" },
        "label": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "enum": ["string", "date"] },
        "value": { "$ref": "#/$defs/accessValueString" }
      },
      "additionalProperties": false
    },

    "metadataNodeItem": {
      "type": "object",
      "required": ["kind", "label", "value",
        "property"
      ],
      "properties": {
        "kind": { "const": "node" },
        "label": { "type": "string", "minLength": 1 },
        "format": { "type": "string", "enum": ["string", "date"] },
        "value": { "$ref": "#/$defs/access" },
        "property": { "type": "string", "minLength": 1 },
        "isLinked": { "type": "boolean" }
      },
      "additionalProperties": false
    },

    "metadataBlock": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": { "const": "metadata" },
        "properties": {
          "type": "object",
          "required": ["items"],
          "properties": {
            "title": { "$ref": "#/$defs/accessValueString" },
            "items": {
              "type": "array",
              "items": {
                "oneOf": [
                  { "$ref": "#/$defs/metadataValueItem" },
                  { "$ref": "#/$defs/metadataNodeItem" }
                ]
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "block": {
      "oneOf": [
        { "$ref": "#/$defs/headlineBlock" },
        { "$ref": "#/$defs/metadataBlock" },
        { "$ref": "#/$defs/textBlock" }
      ]
    },

    "detailScreen": {
      "type": "object",
      "required": ["match", "blocks"],
      "properties": {
        "match": {
          "type": "array",
          "items": { "$ref": "#/$defs/typeKey" },
          "minItems": 1
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        }
      },
      "additionalProperties": false
    },

    "screens": {
      "type": "object",
      "required": ["entities", "collections", "collection", "entity"],
      "properties": {
        "entities": { "$ref": "#/$defs/entityListScreen" },
        "collections": { "$ref": "#/$defs/listScreen" },
        "collection": {
          "type": "array",
          "items": { "$ref": "#/$defs/detailScreen" }
        },
        "entity": {
          "type": "array",
          "items": { "$ref": "#/$defs/detailScreen" }
        }
      },
      "additionalProperties": false
    }
  }
}
