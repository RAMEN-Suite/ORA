{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/screens.schema.json",
  "title": "ORA Screens",
  "$ref": "#/$defs/screens",

  "$defs": {
    "typeKey": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
    },

    "queryPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:\\[\\]*-]+$"
    },

    "propertyName": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },

    "valueMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },

    "labeled": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "icon": {
          "type": "string"
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },

    "typeChoice": {
      "allOf": [
        {
          "$ref": "#/$defs/labeled"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "$ref": "#/$defs/typeKey"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "pathChoice": {
      "allOf": [
        {
          "$ref": "#/$defs/labeled"
        },
        {
          "type": "object",
          "properties": {
            "value": {
              "$ref": "#/$defs/queryPath"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "property": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "$ref": "#/$defs/propertyName"
        },
        "display": {
          "type": "string"
        },
        "valueMap": {
          "$ref": "#/$defs/valueMap"
        }
      },
      "additionalProperties": false
    },

    "filterChoice": {
      "allOf": [
        {
          "$ref": "#/$defs/pathChoice"
        },
        {
          "type": "object",
          "properties": {
            "display": {
              "type": "string",
              "enum": ["list", "range"]
            },
            "valueMap": {
              "$ref": "#/$defs/valueMap"
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "sortSelection": {
      "type": "object",
      "required": ["initial", "options", "direction"],
      "properties": {
        "initial": {
          "$ref": "#/$defs/queryPath"
        },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathChoice"
          }
        }
      },
      "additionalProperties": false
    },

    "listItem": {
      "allOf": [
        {
          "$ref": "#/$defs/typeChoice"
        },
        {
          "type": "object",
          "properties": {
            "properties": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/property"
              }
            },
            "sort": {
              "$ref": "#/$defs/sortSelection"
            },
            "filters": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/filterChoice"
              }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "entityItem": {
      "allOf": [
        {
          "$ref": "#/$defs/typeChoice"
        },
        {
          "type": "object",
          "properties": {
            "properties": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/property"
              }
            },
            "index": {
              "type": "string",
              "enum": ["character", "bible"]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "listView": {
      "type": "object",
      "required": ["initial", "items"],
      "properties": {
        "initial": {
          "$ref": "#/$defs/typeKey"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/listItem"
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      },
      "additionalProperties": false
    },

    "entityListView": {
      "type": "object",
      "required": ["initial", "items"],
      "properties": {
        "initial": {
          "$ref": "#/$defs/typeKey"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entityItem"
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      },
      "additionalProperties": false
    },

    "stringBinding": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "$ref": "#/$defs/queryPath"
        },
        "fallback": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },

    "stringOrStringArrayBinding": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "$ref": "#/$defs/queryPath"
        },
        "fallback": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },

    "stringValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/stringBinding"
        }
      ]
    },

    "stringOrStringArrayValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        {
          "$ref": "#/$defs/stringOrStringArrayBinding"
        }
      ]
    },

    "headlineProps": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "$ref": "#/$defs/stringValue"
        }
      },
      "additionalProperties": false
    },

    "metadataItem": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": {
          "$ref": "#/$defs/stringValue"
        },
        "value": {
          "$ref": "#/$defs/stringOrStringArrayValue"
        }
      },
      "additionalProperties": false
    },

    "metadataProps": {
      "type": "object",
      "required": ["items"],
      "properties": {
        "title": {
          "$ref": "#/$defs/stringValue"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metadataItem"
          }
        },
        "link": {
          "type": "string",
          "enum": ["entity", "collection"]
        }
      },
      "additionalProperties": false
    },

    "textProps": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "title": {
          "$ref": "#/$defs/stringValue"
        },
        "text": {
          "$ref": "#/$defs/stringValue"
        }
      },
      "additionalProperties": false
    },

    "headlineBlock": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "const": "headline"
        },
        "properties": {
          "$ref": "#/$defs/headlineProps"
        }
      },
      "additionalProperties": false
    },

    "metadataBlock": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "const": "metadata"
        },
        "properties": {
          "$ref": "#/$defs/metadataProps"
        }
      },
      "additionalProperties": false
    },

    "textBlock": {
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "const": "text"
        },
        "properties": {
          "$ref": "#/$defs/textProps"
        }
      },
      "additionalProperties": false
    },

    "block": {
      "oneOf": [
        {
          "$ref": "#/$defs/headlineBlock"
        },
        {
          "$ref": "#/$defs/metadataBlock"
        },
        {
          "$ref": "#/$defs/textBlock"
        }
      ]
    },

    "detailView": {
      "type": "object",
      "required": ["match", "blocks"],
      "properties": {
        "match": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/typeKey"
          },
          "minItems": 1
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        }
      },
      "additionalProperties": false
    },

    "screens": {
      "type": "object",
      "required": ["entities", "collections", "collection", "entity"],
      "properties": {
        "entities": {
          "$ref": "#/$defs/entityListView"
        },
        "collections": {
          "$ref": "#/$defs/listView"
        },
        "collection": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detailView"
          }
        },
        "entity": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detailView"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
