{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/features.schema.json",
  "title": "ORA Features",
  "$ref": "#/$defs/features",
  "$defs": {
    "bibleBook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "aliases"],
      "properties": {
        "key": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bible"],
      "properties": {
        "bible": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bibleBook"
          }
        }
      }
    }
  }
}
