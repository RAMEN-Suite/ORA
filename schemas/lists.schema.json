{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/lists.schema.json",
  "title": "ORA Lists",
  "$ref": "#/$defs/listViews",
  "$defs": {
    "bindingPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:\\[\\]*-]+$"
    },
    "sortDirection": {
      "type": "string",
      "enum": ["asc", "desc"]
    },
    "entityIndex": {
      "type": "string",
      "enum": ["character", "bible"]
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "property": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "$ref": "#/$defs/bindingPath"
        },
        "display": {
          "type": "string"
        },
        "valueMap": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "filterOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "icon": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "display": {
          "type": "string",
          "enum": ["list", "range"]
        },
        "value": {
          "$ref": "#/$defs/bindingPath"
        },
        "valueMap": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "sortOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "icon": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "$ref": "#/$defs/bindingPath"
        }
      }
    },
    "sortOptionGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial", "options", "direction"],
      "properties": {
        "initial": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sortOption"
          }
        },
        "direction": {
          "$ref": "#/$defs/sortDirection"
        }
      }
    },
    "listOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "icon": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "sort": {
          "$ref": "#/$defs/sortOptionGroup"
        },
        "filters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/filterOption"
          }
        }
      }
    },
    "entityOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value"],
      "properties": {
        "icon": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        },
        "index": {
          "$ref": "#/$defs/entityIndex"
        }
      }
    },
    "entityListView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial", "options"],
      "properties": {
        "initial": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entityOption"
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      }
    },
    "collectionListView": {
      "type": "object",
      "additionalProperties": false,
      "required": ["initial", "options"],
      "properties": {
        "initial": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/listOption"
          }
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/property"
          }
        }
      }
    },
    "listViews": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entities", "collections"],
      "properties": {
        "entities": {
          "$ref": "#/$defs/entityListView"
        },
        "collections": {
          "$ref": "#/$defs/collectionListView"
        }
      }
    }
  }
}
