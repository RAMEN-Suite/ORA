{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ramen-schema.org/ora/2026.1/screens.schema.json",
  "title": "ORA Screens Configuration",
  "$ref": "#/$defs/screensConfig",

  "$defs": {
    "queryPath": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:[\\]-]+$"
    },

    "propertyName": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },

    "option": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "icon": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },

    "queryOption": {
      "allOf": [
        { "$ref": "#/$defs/option" },
        {
          "type": "object",
          "properties": {
            "value": { "$ref": "#/$defs/queryPath" }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "propertyConfig": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/propertyName" },
        "display": { "type": "string" },
        "valueMap": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "filterOption": {
      "allOf": [
        { "$ref": "#/$defs/queryOption" },
        {
          "type": "object",
          "properties": {
            "display": {
              "type": "string",
              "enum": ["list", "range"]
            },
            "valueMap": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "selection": {
      "type": "object",
      "required": ["initial", "options"],
      "properties": {
        "initial": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        }
      },
      "additionalProperties": false
    },

    "sortSelection": {
      "allOf": [
        { "$ref": "#/$defs/selection" },
        {
          "type": "object",
          "required": ["direction"],
          "properties": {
            "direction": {
              "type": "string",
              "enum": ["asc", "desc"]
            },
            "options": {
              "type": "array",
              "items": { "$ref": "#/$defs/queryOption" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "optionWithProperties": {
      "allOf": [
        { "$ref": "#/$defs/option" },
        {
          "type": "object",
          "properties": {
            "properties": {
              "type": "array",
              "items": { "$ref": "#/$defs/propertyConfig" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "collectionNode": {
      "allOf": [
        { "$ref": "#/$defs/optionWithProperties" },
        {
          "type": "object",
          "properties": {
            "sort": { "$ref": "#/$defs/sortSelection" },
            "filters": {
              "type": "array",
              "items": { "$ref": "#/$defs/filterOption" }
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "entityNode": {
      "allOf": [
        { "$ref": "#/$defs/optionWithProperties" },
        {
          "type": "object",
          "properties": {
            "index": {
              "type": "string",
              "enum": ["character", "bible"]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    },

    "collectionListScreen": {
      "type": "object",
      "required": ["initial", "nodes"],
      "properties": {
        "initial": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/collectionNode" }
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/propertyConfig" }
        }
      },
      "additionalProperties": false
    },

    "entityListScreen": {
      "type": "object",
      "required": ["initial", "nodes"],
      "properties": {
        "initial": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/entityNode" }
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/propertyConfig" }
        }
      },
      "additionalProperties": false
    },

    "stringBinding": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "$ref": "#/$defs/queryPath" },
        "fallback": { "type": "string" }
      },
      "additionalProperties": false
    },

    "stringOrStringArrayBinding": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "$ref": "#/$defs/queryPath" },
        "fallback": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": "string" }
            }
          ]
        }
      },
      "additionalProperties": false
    },

    "stringValue": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/stringBinding" }
      ]
    },

    "stringOrStringArrayValue": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        },
        { "$ref": "#/$defs/stringOrStringArrayBinding" }
      ]
    },

    "headlineBlockProps": {
      "type": "object",
      "required": ["title"],
      "patternProperties": {
        "^title$": { "$ref": "#/$defs/stringValue" }
      },
      "additionalProperties": false
    },

    "metadataItem": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": { "$ref": "#/$defs/stringValue" },
        "value": { "$ref": "#/$defs/stringOrStringArrayValue" }
      },
      "additionalProperties": false
    },

    "metadataBlockProps": {
      "type": "object",
      "required": ["items"],
      "patternProperties": {
        "^title$": { "$ref": "#/$defs/stringValue" },
        "^items$": {
          "type": "array",
          "items": { "$ref": "#/$defs/metadataItem" }
        },
        "^link$": {
          "type": "string",
          "enum": ["entity", "collection"]
        }
      },
      "additionalProperties": false
    },

    "textBlockProps": {
      "type": "object",
      "required": ["text"],
      "patternProperties": {
        "^title$": { "$ref": "#/$defs/stringValue" },
        "^text$": { "$ref": "#/$defs/stringValue" }
      },
      "additionalProperties": false
    },

    "headlineBlock": {
      "type": "object",
      "required": ["type", "props"],
      "patternProperties": {
        "^type$": { "enum": ["headline"] },
        "^props$": { "$ref": "#/$defs/headlineBlockProps" }
      },
      "additionalProperties": false
    },

    "metadataBlock": {
      "type": "object",
      "required": ["type", "props"],
      "patternProperties": {
        "^type$": { "enum": ["metadata"] },
        "^props$": { "$ref": "#/$defs/metadataBlockProps" }
      },
      "additionalProperties": false
    },

    "textBlock": {
      "type": "object",
      "required": ["type", "props"],
      "patternProperties": {
        "^type$": { "enum": ["text"] },
        "^props$": { "$ref": "#/$defs/textBlockProps" }
      },
      "additionalProperties": false
    },

    "screenBlock": {
      "oneOf": [
        { "$ref": "#/$defs/headlineBlock" },
        { "$ref": "#/$defs/metadataBlock" },
        { "$ref": "#/$defs/textBlock" }
      ]
    },

    "composedScreen": {
      "type": "object",
      "required": ["blocks"],
      "properties": {
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/screenBlock" }
        }
      },
      "additionalProperties": false
    },

    "screensConfig": {
      "type": "object",
      "required": ["entities", "collections", "collection", "entity"],
      "properties": {
        "entities": { "$ref": "#/$defs/entityListScreen" },
        "collections": { "$ref": "#/$defs/collectionListScreen" },
        "collection": {
          "type": "array",
          "items": { "$ref": "#/$defs/composedScreen" }
        },
        "entity": {
          "type": "array",
          "items": { "$ref": "#/$defs/composedScreen" }
        }
      },
      "additionalProperties": false
    }
  }
}
