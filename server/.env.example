# -----------------------------------------------------------------------------
# ORA server
# -----------------------------------------------------------------------------

# Runtime environment. Use "dev" locally and "prod" in deployments.
NODE_ENV="dev"

# Logging verbosity. Common values: "debug", "info", "warn", "error".
LOG_LEVEL="info"

# HTTP port used by the ORA server inside the container/process.
ORA_SERVER_PORT="3000"

# Directory containing ORA configuration files.
CONFIGURATION_PATH="../config"

# Directory containing translation files.
LANGUAGES_PATH="../i18n"

# Directory containing markdown content files.
MARKDOWN_PATH="../markdown"

# Directory containing static asset files.
ASSETS_PATH="../assets"

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------

# Neo4j connection URI.
NEO4J_HOST="neo4j+s://example.com"

# Neo4j username.
NEO4J_USERNAME="neo4j"

# Neo4j password.
NEO4J_PASSWORD="password"
