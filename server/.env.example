# -----------------------------------------------------------------------------
# ORA server
# -----------------------------------------------------------------------------

# Runtime environment. Use "dev" locally and "prod" in deployments.
NODE_ENV="dev"

# Logging verbosity. Common values: "debug", "info", "warn", "error".
LOG_LEVEL="info"

# HTTP port used by the ORA server inside the container/process.
ORA_SERVER_PORT="3000"

# Directory containing ORA configuration files.
CONFIGURATION_PATH="../config"

# Directory containing translation files.
LANGUAGES_PATH="../i18n"

# Directory containing markdown content files.
MARKDOWN_PATH="../markdown"

# Directory containing static asset files.
ASSETS_PATH="../assets"

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------

# Neo4j connection URI.
NEO4J_HOST="neo4j+s://example.com"

# Neo4j username.
NEO4J_USERNAME="neo4j"

# Neo4j password.
NEO4J_PASSWORD="password"

# -----------------------------------------------------------------------------
# OpenAPI
# -----------------------------------------------------------------------------

# Comma-separated server URLs for the ORA OpenAPI spec.
OPENAPI_ORA_SERVERS="https://ora.domain.de/"

# OpenAPI specification version.
OPENAPI_VERSION="3.0.1"

# Title prefix used for generated OpenAPI documents.
OPENAPI_TITLE="ORA API Gateway:"

# Version of the ORA API described by the generated OpenAPI documents.
OPENAPI_API_VERSION="1.0.0"

# Enables global basicAuth security definition in generated OpenAPI specs.
OPENAPI_SECURITY_ENABLED="true"
