{
  "overrides": [
    {
      "files": "*.html",
      "options": {
        "printWidth": 140,
        "parser": "angular"
      }
    },
    {
      "files": ["*.scss", "*.css"],
      "options": {
        "printWidth": 200,
        "singleQuote": true
      }
    }
  ],
  "plugins": ["prettier-plugin-tailwindcss"]
}
