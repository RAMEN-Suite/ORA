{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,

  "singleQuote": true,
  "jsxSingleQuote": true,
  "quoteProps": "as-needed",

  "semi": true,
  "trailingComma": "all",

  "bracketSpacing": true,
  "bracketSameLine": false,

  "arrowParens": "always",
  "endOfLine": "lf",

  "htmlWhitespaceSensitivity": "css",
  "singleAttributePerLine": false,

  "overrides": [
    {
      "files": "*.html",
      "options": {
        "printWidth": 140,
        "parser": "angular"
      }
    },
    {
      "files": ["*.scss", "*.css"],
      "options": {
        "singleQuote": false
      }
    }
  ],
  "plugins": ["prettier-plugin-tailwindcss"]
}
