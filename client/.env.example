# -----------------------------------------------------------------------------
# ORA client
# -----------------------------------------------------------------------------

# Primary language of the rendered HTML document.
ORA_CLIENT_LANG="de"

# Initial browser/tab title rendered in index.html.
ORA_CLIENT_TITLE="ORA – Graph-based Digital Edition"

# Initial meta description rendered in index.html.
ORA_CLIENT_DESCRIPTION="The victor shall write the tale, and the vanquished become its villain."

# Angular base href. Use "/" for root deployments or "/ora/" for subpath deployments.
ORA_CLIENT_BASE_HREF="/"

# Favicon href rendered in index.html.
ORA_CLIENT_FAVICON_HREF="/favicon.ico"
